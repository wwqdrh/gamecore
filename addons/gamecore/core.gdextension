[infomation]
name = "gamekit-core"
version = "v0.0.7"
decription = "game core logic framework."
author = "wwqdrh"

[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.2"
reloadable = true

[libraries]

macos.debug = "res://addons/gamecore/bin/macos/libgamecore.macos.template_debug.framework"
macos.release = "res://addons/gamecore/bin/macos/libgamecore.macos.template_release.framework"
ios.debug = "res://addons/gamecore/bin/ios/libgamecore.ios.template_debug.framework"
ios.release = "res://addons/gamecore/bin/ios/libgamecore.ios.template_release.framework"
windows.debug.x86_32 = "res://addons/gamecore/bin/windows/libgamecore.windows.template_debug.x86_32.dll"
windows.release.x86_32 = "res://addons/gamecore/bin/windows/libgamecore.windows.template_release.x86_32.dll"
windows.debug.x86_64 = "res://addons/gamecore/bin/windows/libgamecore.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/gamecore/bin/windows/libgamecore.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "res://addons/gamecore/bin/linux/libgamecore.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/gamecore/bin/linux/libgamecore.linux.template_release.x86_64.so"
linux.debug.arm64 = "res://addons/gamecore/bin/linux/libgamecore.linux.template_debug.arm64.so"
linux.release.arm64 = "res://addons/gamecore/bin/linux/libgamecore.linux.template_release.arm64.so"
linux.debug.rv64 = "res://addons/gamecore/bin/linux/libgamecore.linux.template_debug.rv64.so"
linux.release.rv64 = "res://addons/gamecore/bin/linux/libgamecore.linux.template_release.rv64.so"
android.debug.x86_64 = "res://addons/gamecore/bin/android/libgamecore.android.template_debug.x86_64.so"
android.release.x86_64 = "res://addons/gamecore/bin/android/libgamecore.android.template_release.x86_64.so"
android.debug.arm64 = "res://addons/gamecore/bin/android/libgamecore.android.template_debug.arm64.so"
android.release.arm64 = "res://addons/gamecore/bin/android/libgamecore.android.template_release.arm64.so"
android.debug.arm32 = "res://addons/gamecore/bin/android/libgamecore.android.template_debug.arm32.so"
android.release.arm32 = "res://addons/gamecore/bin/android/libgamecore.android.template_release.arm32.so"
web.debug.wasm32 = "res://addons/gamecore/bin/web/libgamecore.web.template_debug.wasm32.wasm"
web.release.wasm32 = "res://addons/gamecore/bin/web/libgamecore.web.template_release.wasm32.wasm"
